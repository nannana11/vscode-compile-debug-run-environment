{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe compile and run",
            "command": "C:\\Program Files (x86)\\Dev-Cpp\\MinGW64\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                "-std=c11"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "the tasks generated by the compiler"
        },
        {
            "label": "run the program ,keep the window",
            "type": "shell",
            "command": "Start-Process cmd -ArgumentList '/k', '\"${fileDirname}\\${fileBasenameNoExtension}.exe\" & pause'",
            "dependsOn": "C/C++: gcc.exe compile and run",
            "presentation": {
                "echo": true,
                "reveal": "never",
                "focus": true,
                "panel": "shared"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ],
    "version": "2.0.0"
}
